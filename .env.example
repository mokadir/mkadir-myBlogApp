# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/modernblog?schema=public"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-change-this-use-openssl-rand-base64-32"

# Google OAuth
# Get these from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Cloudinary
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Email (SMTP / Nodemailer)
# Used for sending notification emails, newsletters, and password resets
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="noreply@modernblog.com"
EMAIL_FROM_NAME="ModernBlog"

# Email (Resend) - Alternative to SMTP
# Get your API key from https://resend.com
# RESEND_API_KEY="re_xxxxxxxxxxxx"

# Cron Jobs
# Secret key to secure cron job endpoints from unauthorized access
CRON_SECRET="your-cron-secret-change-this"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="ModernBlog"